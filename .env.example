# AI 提供商：openai 或 anthropic
AI_PROVIDER=openai

# API 密钥（与智谱控制台「API Key」一致；不要用 JSON，一行 KEY=value）
AI_API_KEY=your-api-key

# API 基础地址
# OpenAI 兼容（AI_PROVIDER=openai）：智谱 https://open.bigmodel.cn/api/paas/v4/
# Anthropic 兼容（AI_PROVIDER=anthropic）：智谱 https://open.bigmodel.cn/api/anthropic
# DeepSeek：https://api.deepseek.com/v1
# OpenAI：https://api.openai.com/v1
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 模型名称
# 智谱 OpenAI 兼容：glm-4-flash、glm-4-plus 等（以控制台为准）
# 智谱 Anthropic 兼容：以控制台开放模型名为准；无权限时会返回 403
# DeepSeek：deepseek-chat
# OpenAI：gpt-4o
# 官方 Anthropic：claude-sonnet-4-20250514
AI_MODEL=glm-4-flash

# 最大生成 token 数
AI_MAX_TOKENS=16000
